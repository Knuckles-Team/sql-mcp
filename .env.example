# Named connections (JSON). DSN strings or {dialect, host, port, username,
# password, database, options} objects. Takes priority over SQL_URL.
# SQL_CONNECTIONS={"warehouse": "postgresql+psycopg://svc:password@db:5432/dw"}

# Single connection (registered as "default")
# SQL_URL=postgresql+psycopg://svc:password@db.example.com:5432/app

# ... or discrete fields for a single "default" connection
# SQL_DIALECT=postgres
# SQL_HOST=db.example.com
# SQL_PORT=5432
# SQL_USERNAME=svc
# SQL_PASSWORD=
# SQL_DATABASE=app
# SQL_OPTIONS={"sslmode": "require"}

# Policy (read-only by default)
# SQL_ALLOW_WRITES=False
# SQL_MAX_ROWS=500
# SQL_TIMEOUT_SECONDS=30

# Register the SQL tool set
# SQLTOOL=True
